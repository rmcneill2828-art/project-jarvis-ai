{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JARVIS Guardian Shell",
  "version": "0.1.0",
  "identifier": "ai.jarvis.guardian-shell",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "JARVIS Guardian Desktop Platform Shell",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}